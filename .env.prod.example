APP_ENV=production
SECRET_KEY=__GENERATE_A_LONG_RANDOM_64_CHAR_STRING__
LOG_LEVEL=INFO

POSTGRES_USER=gtp
POSTGRES_PASSWORD=__STRONG_DB_PASSWORD__
POSTGRES_DB=gold_trading
DATABASE_URL=postgresql+asyncpg://gtp:__STRONG_DB_PASSWORD__@db:5432/gold_trading

REDIS_URL=redis://redis:6379/0

HTTP_PORT=80
CORS_ORIGINS=https://your-domain.example

ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=__CHANGE_THIS_STRONG_ADMIN_PASSWORD__

# Trading safety — paper default; live ordering is disabled in code.
TRADING_MODE=paper
GLOBAL_KILL_SWITCH=false
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
DEFAULT_RISK_PER_TRADE_PCT=0.5
MAX_OPEN_POSITIONS=3
