APP_ENV=development
SECRET_KEY=dev_secret_change_me_to_something_long
LOG_LEVEL=INFO

# Database (PostgreSQL/TimescaleDB in Docker)
POSTGRES_USER=gtp
POSTGRES_PASSWORD=gtp_dev
POSTGRES_DB=gold_trading
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://gtp:gtp_dev@db:5432/gold_trading

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Admin seed
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin

# CORS
CORS_ORIGINS=http://localhost:5173

# Trading safety
TRADING_MODE=paper
GLOBAL_KILL_SWITCH=false
MAX_DAILY_LOSS_PCT=2.0
MAX_DRAWDOWN_PCT=10.0
DEFAULT_RISK_PER_TRADE_PCT=0.5
MAX_OPEN_POSITIONS=3
